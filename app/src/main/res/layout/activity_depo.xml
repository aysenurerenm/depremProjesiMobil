<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Üst Başlık Paneli (AFAD Yeşili) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#10B981"
        android:padding="16dp"
        android:elevation="4dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←  Depo Yönetimi"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Özet Kartları (Horizontal Scroll) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:orientation="horizontal">

                <!-- Toplam Kalem -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#059669"
                    app:cardCornerRadius="12dp"
                    android:layout_marginEnd="10dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toplam Kalem"
                            android:textColor="#D1FAE5"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/txtToplamKalem"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Kritik Stok -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#059669"
                    app:cardCornerRadius="12dp"
                    android:layout_marginEnd="10dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kritik Stok"
                            android:textColor="#D1FAE5"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/txtKritikStok"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Aktif Sevkiyat -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#059669"
                    app:cardCornerRadius="12dp"
                    android:layout_marginEnd="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aktif Sevkiyat"
                            android:textColor="#D1FAE5"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/txtAktifSevkiyat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
    <Button
        android:id="@+id/btnAlanIhtiyaclari"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Toplanma Alanı İhtiyaçlarını Görüntüle"
        android:backgroundTint="#10B981"
        android:textColor="#FFFFFF"
        app:cornerRadius="8dp" />
    <Button
        android:id="@+id/btnSevkiyatlar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sevkiyattaki Ürünler"
        android:layout_marginTop="12dp"
        android:backgroundTint="#3B82F6"
        android:textColor="#FFFFFF"/>
    <Button
        android:id="@+id/btnTamamlananlar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tamamlanan Yardımlar"
        android:layout_marginTop="8dp"/>

    <!-- Kritik Stok Uyarı Barı -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layoutKritikUyari"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FEF2F2"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/stat_sys_warning"
                app:tint="#EF4444"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="3 ürün kritik stok seviyesinde!"
                android:textColor="#B91C1C"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- DEPOYA ÜRÜN EKLE -->

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDepoEkle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TIKLANABİLİR BAŞLIK -->

            <LinearLayout
                android:id="@+id/layoutHeaderDepo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Depoya Ürün Ekle"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/imgArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/arrow_down_float"/>
            </LinearLayout>

            <!-- AÇILIP KAPANAN İÇERİK -->

            <LinearLayout
                android:id="@+id/layoutDepoContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone">

                <!-- Spinner -->

                <Spinner
                    android:id="@+id/spinnerUrunler"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"/>

                <!-- Miktar -->

                <EditText
                    android:id="@+id/etMiktar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Miktar Giriniz"
                    android:inputType="number"
                    android:padding="12dp"/>

                <!-- Buton -->

                <Button
                    android:id="@+id/btnDepoyaEkle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="#10B981"
                    android:text="Ürünü Depoya Ekle"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:text="Stok Durumu"
        android:textColor="#4B5563"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Ürün Listesi (0dp ve weight: 1 ile kalan tüm alanı kaplamasını sağladık) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewStok"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>