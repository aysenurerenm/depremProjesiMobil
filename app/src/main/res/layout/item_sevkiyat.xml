<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtSurucu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sürücü Adı"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/txtDurum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#3B82F6"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Sevkiyatta"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txtPlaka"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Plaka" />

        <TextView
            android:id="@+id/txtArac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Araç Tipi" />

        <TextView
            android:id="@+id/txtAlan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hedef Alan" />

        <TextView
            android:id="@+id/txtSevkiyatZamani"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Yola Çıkış: ---"
            android:textColor="#555555"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtOnayZamani"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Zaman"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtMiktar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Adet"
                android:textStyle="bold"
                android:textColor="#10B981" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>