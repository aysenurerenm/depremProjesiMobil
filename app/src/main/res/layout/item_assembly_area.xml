<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toplanma Alanı Başlığı -->
        <TextView
            android:id="@+id/txtAreaName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toplanma Alanı: Yükleniyor..."
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#DDDDDD" />

        <!-- Konum Bilgisi -->
        <TextView
            android:id="@+id/txtAreaLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@android:drawable/ic_dialog_map"
            android:drawablePadding="8dp"
            android:text="Konum: --, --"
            android:textSize="14sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <!-- Yetkili Bilgisi -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alan Yetkilisi"
            android:textAllCaps="true"
            android:textColor="@color/purple_700"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtOfficerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ad Soyad: --"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtOfficerPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autoLink="phone"
            android:text="Telefon: --"
            android:textColorLink="@color/purple_500"
            android:textSize="15sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>