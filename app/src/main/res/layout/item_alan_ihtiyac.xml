<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardMaxElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtAlanAdi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Toplanma Alanı Adı"
                android:textColor="#111827"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSevkiyatDurumu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FDF5F2"
                android:backgroundTint="#3B82F6"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Hazırlanıyor"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtZamanBilgi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Talep: 09.05.2026 21:54"
                android:textSize="12sp"
                android:textColor="#6B7280" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E5E7EB" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#6B7280" />

            <TextView
                android:id="@+id/txtUrunBilgi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Ürün: Powerbank"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtMiktarBilgi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50 Adet"
                android:textColor="#10B981"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ONAYLA BUTONU -->
        <Button
            android:id="@+id/btnOnayla"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#10B981"
            android:text="Talebi Onayla"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>